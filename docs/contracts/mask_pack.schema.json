{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://art-code.local/contracts/mask_pack.schema.json",
  "title": "Mask Pack",
  "type": "object",
  "required": [
    "version"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "regionMaskUrl": {
      "type": "string",
      "minLength": 1
    },
    "edgeMaskUrl": {
      "type": "string",
      "minLength": 1
    },
    "confidenceUrl": {
      "type": "string",
      "minLength": 1
    },
    "regionMask": {
      "type": "string",
      "minLength": 1,
      "description": "Legacy alias of regionMaskUrl"
    },
    "edgeMask": {
      "type": "string",
      "minLength": 1,
      "description": "Legacy alias of edgeMaskUrl"
    },
    "confidenceMask": {
      "type": "string",
      "minLength": 1,
      "description": "Legacy alias of confidenceUrl"
    },
    "regionCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 255
    },
    "encoding": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "anyOf": [
    {
      "required": [
        "regionMaskUrl"
      ]
    },
    {
      "required": [
        "edgeMaskUrl"
      ]
    },
    {
      "required": [
        "confidenceUrl"
      ]
    },
    {
      "required": [
        "regionMask"
      ]
    },
    {
      "required": [
        "edgeMask"
      ]
    },
    {
      "required": [
        "confidenceMask"
      ]
    }
  ],
  "additionalProperties": true
}
